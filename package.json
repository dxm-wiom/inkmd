{
  "name": "inkmd",
  "version": "1.2.2",
  "description": "A beautiful markdown reader",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win --arm64",
    "electron:build:x64": "vite build && electron-builder --win --x64",
    "electron:build:mac": "vite build && electron-builder --mac --arm64",
    "electron:build:mac:x64": "vite build && electron-builder --mac --x64",
    "icons:icns": "node scripts/generate-icns.js"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "build": {
    "appId": "com.inkmd.app",
    "productName": "inkMD",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["arm64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "fileAssociations": [
      { "ext": "md",       "name": "Markdown File", "description": "Markdown Document",   "role": "Editor" },
      { "ext": "markdown", "name": "Markdown File", "description": "Markdown Document",   "role": "Editor" },
      { "ext": "mdown",    "name": "Markdown File", "description": "Markdown Document",   "role": "Editor" },
      { "ext": "mkd",      "name": "Markdown File", "description": "Markdown Document",   "role": "Editor" },
      { "ext": "mdx",      "name": "MDX File",      "description": "MDX Document",        "role": "Editor" },
      { "ext": "txt",      "name": "Text File",     "description": "Plain Text Document", "role": "Editor" },
      { "ext": "json",     "name": "JSON File",     "description": "JSON Document",       "role": "Editor" },
      { "ext": "yaml",     "name": "YAML File",     "description": "YAML Document",       "role": "Editor" },
      { "ext": "yml",      "name": "YAML File",     "description": "YAML Document",       "role": "Editor" },
      { "ext": "toml",     "name": "TOML File",     "description": "TOML Document",       "role": "Editor" },
      { "ext": "csv",      "name": "CSV File",      "description": "CSV Document",        "role": "Editor" },
      { "ext": "spec",     "name": "Spec File",     "description": "Spec Document",       "role": "Editor" },
      { "ext": "log",      "name": "Log File",      "description": "Log Document",        "role": "Editor" },
      { "ext": "ini",      "name": "INI File",      "description": "INI Document",        "role": "Editor" },
      { "ext": "env",      "name": "Env File",      "description": "Environment File",    "role": "Editor" },
      { "ext": "xml",      "name": "XML File",      "description": "XML Document",        "role": "Editor" }
    ]
  }
}
